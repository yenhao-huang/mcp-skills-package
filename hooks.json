{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(pwd)/.codex/hooks/do-cron-tasks.py\"",
            "timeout": 30,
            "statusMessage": "Checking daily cron tasks"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(pwd)/.codex/hooks/check_session_size.py\"",
            "timeout": 30,
            "statusMessage": "Checking session size"
          }
        ]
      }
    ]
  }
}
